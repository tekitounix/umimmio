# Non-interactive Renode script for umitest CI

using sysbus

mach create "umitest_ci"

machine LoadPlatformDescription $CWD/lib/umiport/renode/stm32f4_test.repl

sysbus LoadELF $CWD/build/umitest_stm32f4_renode_gcc/release/umitest_stm32f4_renode_gcc.elf

sysbus WriteDoubleWord 0xE000ED08 0x08000000
sysbus WriteDoubleWord 0x00000000 `sysbus ReadDoubleWord 0x08000000`
sysbus WriteDoubleWord 0x00000004 `sysbus ReadDoubleWord 0x08000004`

usart1 CreateFileBackend $CWD/build/umitest_stm32f4_renode_gcc/release/uart.log true

cpu PerformanceInMips 100
emulation RunFor "2"

usart1 CloseFileBackend $CWD/build/umitest_stm32f4_renode_gcc/release/uart.log
quit
