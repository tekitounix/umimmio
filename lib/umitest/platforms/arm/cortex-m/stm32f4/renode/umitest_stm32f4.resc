# Renode script for umitest (STM32F4 / Cortex-M4)
# Usage: renode --console --disable-xwt -e "include @lib/umitest/platforms/arm/cortex-m/stm32f4/renode/umitest_stm32f4.resc"

using sysbus

mach create "umitest"

machine LoadPlatformDescription $CWD/lib/umiport/renode/stm32f4_test.repl

sysbus LoadELF $CWD/build/umitest_stm32f4_renode/release/umitest_stm32f4_renode.elf

sysbus WriteDoubleWord 0xE000ED08 0x08000000
sysbus WriteDoubleWord 0x00000000 `sysbus ReadDoubleWord 0x08000000`
sysbus WriteDoubleWord 0x00000004 `sysbus ReadDoubleWord 0x08000004`

usart1 CreateFileBackend $CWD/build/umitest_stm32f4_renode/release/uart.log true
showAnalyzer usart1

cpu PerformanceInMips 100

echo "=== umitest STM32F4 Test Starting ==="
emulation RunFor "2"
usart1 CloseFileBackend $CWD/build/umitest_stm32f4_renode/release/uart.log
quit
