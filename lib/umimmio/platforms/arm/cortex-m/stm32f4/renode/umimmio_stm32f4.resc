# Renode script for umimmio (STM32F4 / Cortex-M4)
# Usage: renode --console --disable-xwt -e "include @lib/umimmio/platforms/arm/cortex-m/stm32f4/renode/umimmio_stm32f4.resc"

using sysbus

mach create "umimmio"

machine LoadPlatformDescription $CWD/lib/platforms/arm/cortex-m/stm32f4/renode/stm32f4_test.repl

sysbus LoadELF $CWD/build/umimmio_stm32f4_renode/release/umimmio_stm32f4_renode.elf

sysbus WriteDoubleWord 0xE000ED08 0x08000000
sysbus WriteDoubleWord 0x00000000 `sysbus ReadDoubleWord 0x08000000`
sysbus WriteDoubleWord 0x00000004 `sysbus ReadDoubleWord 0x08000004`

usart1 CreateFileBackend $CWD/build/umimmio_stm32f4_renode/release/uart.log true
showAnalyzer usart1

cpu PerformanceInMips 100

echo "=== umimmio STM32F4 Test Starting ==="
emulation RunFor "2"
usart1 CloseFileBackend $CWD/build/umimmio_stm32f4_renode/release/uart.log
quit
