# Non-interactive Renode script for umirtm CI

using sysbus

mach create "umirtm_ci"

machine LoadPlatformDescription $CWD/lib/platforms/arm/cortex-m/stm32f4/renode/stm32f4_test.repl

sysbus LoadELF $CWD/build/umirtm_stm32f4_renode_gcc/release/umirtm_stm32f4_renode_gcc.elf

sysbus WriteDoubleWord 0xE000ED08 0x08000000
sysbus WriteDoubleWord 0x00000000 `sysbus ReadDoubleWord 0x08000000`
sysbus WriteDoubleWord 0x00000004 `sysbus ReadDoubleWord 0x08000004`

usart1 CreateFileBackend $CWD/build/umirtm_stm32f4_renode_gcc/release/uart.log true

cpu PerformanceInMips 100
emulation RunFor "2"

usart1 CloseFileBackend $CWD/build/umirtm_stm32f4_renode_gcc/release/uart.log
quit
