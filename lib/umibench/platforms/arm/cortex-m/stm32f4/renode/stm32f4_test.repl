// Renode platform description for umibench STM32F4 tests
// Based on STM32F407/STM32F446 built-in platform

using "platforms/cpus/stm32f4.repl"

flash:
    size: 0x80000

boot: Memory.MappedMemory @ sysbus 0x00000000
    size: 0x80000

dwt: Miscellaneous.DWT @ sysbus 0xE0001000
    frequency: 168000000
