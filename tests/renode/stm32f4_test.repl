// Renode Platform Description for umimmio testing
// Based on STM32F407 — minimal config (no MPU/DWT needed)

using "platforms/cpus/stm32f4.repl"

// Override flash size for test image
flash:
    size: 0x80000

// Boot alias at 0x00000000
boot: Memory.MappedMemory @ sysbus 0x00000000
    size: 0x80000
